<Project Sdk="Microsoft.NET.Sdk">

    <PropertyGroup>
        <RootNamespace>AlphaTab</RootNamespace>
        <AssemblyName>AlphaTab.Avalonia</AssemblyName>
        <PackageId>AlphaTab.Avalonia</PackageId>
        <PackageReadmeFile>README.md</PackageReadmeFile>
        <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
        <GenerateDocumentationFile>true</GenerateDocumentationFile>
        <TargetFramework>net8.0-windows</TargetFramework>
        <NoWarn>$(NoWarn);NU5105;618;CA1416</NoWarn>
        <Nullable>enable</Nullable>
        <LangVersion>12</LangVersion>
        <EnableWindowsTargeting>true</EnableWindowsTargeting>
    </PropertyGroup>

    <ItemGroup>
        <ProjectReference Include="..\AlphaTab\AlphaTab.csproj" />
    </ItemGroup>

    <ItemGroup>
        <None Include="..\..\..\..\README.md" Pack="true" PackagePath="\"/>
        <EmbeddedResource Include="..\..\..\alphatab\font\sonivox\sonivox.sf2" Link="default.sf2" />
    </ItemGroup>

    <ItemGroup>
        <PackageReference Include="Avalonia" Version="12.0.1" />
        <PackageReference Include="NAudio" Version="2.3.0" />
        <PackageReference Include="AlphaSkia.Native.Windows" Version="3.5.147" />
    </ItemGroup>

</Project>
