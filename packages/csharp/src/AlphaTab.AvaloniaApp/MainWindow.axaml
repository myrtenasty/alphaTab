<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:at="clr-namespace:AlphaTab.Avalonia;assembly=AlphaTab.Avalonia"
        x:Class="AlphaTab.AvaloniaApp.MainWindow"
        mc:Ignorable="d"
        Title="alphaTab Avalonia"
        Width="1200"
        Height="800"
        MinWidth="800"
        MinHeight="600">
  <Grid RowDefinitions="Auto,Auto,*" Margin="16">
    <StackPanel Grid.Row="0"
                Orientation="Horizontal"
                Spacing="8">
      <Button HorizontalAlignment="Left"
              Content="打开乐谱文件"
              Click="OnOpenFileClick" />
      <Button HorizontalAlignment="Left"
              Content="播放/暂停"
              Click="OnPlayPauseClick" />
      <Button HorizontalAlignment="Left"
              Content="停止"
              Click="OnStopClick" />
    </StackPanel>

    <TextBlock Grid.Row="1"
               Margin="0,12,0,12"
               Text="使用上方按钮控制打开、播放/暂停和停止"
               Opacity="0.75" />

    <Border Grid.Row="2"
            BorderThickness="1"
            CornerRadius="6"
            Padding="8">
      <at:AlphaTab x:Name="AlphaTabView" />
    </Border>
  </Grid>
</Window>
